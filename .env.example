# === LLM Provider API Keys ===
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# === Ollama (Local Models) ===
OLLAMA_BASE_URL=http://localhost:11434

# === Default Model Settings ===
AGENTFORGE_DEFAULT_PROVIDER=openai
AGENTFORGE_DEFAULT_MODEL=gpt-4o
AGENTFORGE_DEFAULT_TEMPERATURE=0.7
AGENTFORGE_DEFAULT_MAX_TOKENS=4096

# === Memory / Vector Store ===
AGENTFORGE_CHROMA_PATH=./chroma_data
AGENTFORGE_MEMORY_COLLECTION=agentforge_memory

# === Server ===
AGENTFORGE_HOST=0.0.0.0
AGENTFORGE_PORT=8000

# === Logging ===
AGENTFORGE_LOG_LEVEL=INFO
